[
    {
        "type": "SQL Injection",
        "severity": "High",
        "patterns": [
            "'\\s*OR\\s*1=1",
            "union\\s+select",
            "drop\\s+table",
            "--"
        ]
    },
    {
        "type": "Cross-Site Scripting (XSS)",
        "severity": "High",
        "patterns": [
